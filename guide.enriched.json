{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mhunsaker/folge-vision-spec/schemas/v1.0/guide.enriched.json",
  "title": "Folge Enriched Guide",
  "description": "Canonical schema for Folge guides enriched with Ollama Vision",
  "type": "object",
  "required": ["schema_version", "guide_id", "title", "steps"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"],
      "description": "Version of this schema"
    },
    "guide_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this guide"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Title of the guide"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional guide description"
    },
    "version": {
      "type": "string",
      "description": "Guide version (semantic versioning recommended)"
    },
    "language": {
      "type": "string",
      "default": "en",
      "description": "Primary language of the guide"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the guide was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the guide was last updated"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "title", "body"],
        "additionalProperties": false,
        "properties": {
          "step_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Primary key for deterministic merging"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Step title"
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "description": "Step instructions"
          },
          "image": {
            "type": "string",
            "description": "Path to screenshot image"
          },
          "order": {
            "type": "integer",
            "minimum": 0,
            "description": "Explicit ordering (defaults to step_id if omitted)"
          },
          "vision": {
            "type": "object",
            "description": "AI-generated vision enrichment (separate from authored content)",
            "required": ["alt_text", "long_description", "confidence", "model", "generated_at"],
            "additionalProperties": false,
            "properties": {
              "alt_text": {
                "type": "string",
                "maxLength": 150,
                "description": "Concise alternative text for accessibility"
              },
              "long_description": {
                "type": "string",
                "maxLength": 1000,
                "description": "Detailed description for accessibility"
              },
              "ocr_text": {
                "type": "array",
                "items": {"type": "string"},
                "maxItems": 50,
                "description": "Visible text extracted via OCR"
              },
              "ui_controls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type", "label"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["button", "text_field", "dropdown", "checkbox", "radio", "slider", "navigation", "menu", "tab", "icon", "link", "other"]
                    },
                    "label": {"type": "string"},
                    "bounding_box": {
                      "type": "object",
                      "properties": {
                        "x": {"type": "number"},
                        "y": {"type": "number"},
                        "width": {"type": "number"},
                        "height": {"type": "number"}
                      }
                    },
                    "action": {"type": "string"}
                  }
                },
                "description": "Detected UI controls"
              },
              "important_element": {
                "type": "string",
                "maxLength": 200,
                "description": "Primary element user should focus on"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Model confidence score"
              },
              "model": {
                "type": "string",
                "description": "Model used for enrichment"
              },
              "generated_at": {
                "type": "string",
                "format": "date-time",
                "description": "When vision enrichment was generated"
              },
              "processing_time_ms": {
                "type": "integer",
                "description": "Time taken for vision processing"
              }
            }
          },
          "metadata": {
            "type": "object",
            "description": "Optional step-level metadata",
            "additionalProperties": true
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Guide-level metadata",
      "additionalProperties": true
    }
  }
}
